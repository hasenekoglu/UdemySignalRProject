@model List<ResultProductDto>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Urun Islemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<div class="card">
					<div class="card-header">
						<div class="card-title">Urun Listesi</div>
					</div>
					<div class="card-body">
						<div class="card-sub">
							Urun ile ilgili islemleri asagida gerceklestirebilirsiniz.
						</div>
						<table class="table mt-3">
							<thead>
								<tr>
									<th scope="col">#</th>
									<th scope="col">Urun Adi</th>
									<th scope="col">Fiyat</th>
									<th scope="col">Kategori</th>
									<th scope="col">Durum</th>
									<th scope="col">Sil</th>
									<th scope="col">Guncelle</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var item in Model)
								{
									<tr>
										<td>@item.ProductId</td>
										<td>@item.ProductName</td>
										<td>@item.Price</td>
										<td>@item.CategoryName</td>
										<td>@item.Status</td>
										<td><a href="/Product/DeleteProduct/@item.ProductId" class="btn btn-outline-danger btn-round">Sil</a></td>
										<td><a href="/Product/UpdateProduct/@item.ProductId" class="btn btn-outline-success btn-round">Guncelle</a></td>
									</tr>
								}

							</tbody>
						</table>
						<a href="/Product/CreateProduct/" class="btn btn-outline-primary">Yeni Urun Girisi</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

