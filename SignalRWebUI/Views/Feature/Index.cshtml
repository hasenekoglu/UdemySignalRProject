@model List<ResultFeatureDto>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">One Cikan Alan Islemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<div class="card">
					<div class="card-header">
						<div class="card-title">One Cikan Listesi</div>
					</div>
					<div class="card-body">
						<div class="card-sub">
							Ana Sayfada One Cikan ile ilgili islemleri asagida gerceklestirebilirsiniz.
						</div>
						<table class="table mt-3">
							<thead>
								<tr>
									<th scope="col">#</th>
									<th scope="col">Baslik 1</th>
									<th scope="col">Baslik 2</th>
									<th scope="col">Baslik 3</th>
									<th scope="col">Aciklama 1</th>
									<th scope="col">Aciklama 2</th>
									<th scope="col">Aciklama 3</th>
									<th scope="col">Sil</th>
									<th scope="col">Guncelle</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var item in Model)
								{
									<tr>
										<td>@item.FeatureId</td>
										<td>@item.Title1</td>
										<td>@item.Title2</td>
										<td>@item.Title3</td>
										<td>@item.Descripton1</td>
										<td>@item.Descripton2</td>
										<td>@item.Descripton3</td>
										<td><a href="/Feature/DeleteFeature/@item.FeatureId" class="btn btn-outline-danger btn-round">Sil</a></td>
										<td><a href="/Feature/UpdateFeature/@item.FeatureId" class="btn btn-outline-success btn-round">Guncelle</a></td>
									</tr>
								}

							</tbody>
						</table>
						<a href="/Feature/CreateFeature/" class="btn btn-outline-primary">Yeni One Cikan Girisi</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

