@model UpdateAboutDto
@{
	ViewData["Title"] = "UpdateAbout";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Ana Sayfa Hakkimizda Islemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Yeni Hakkimizda Yazi Guncelleme Sayfasi</div>
						</div>
						<input type="hidden" asp-for="AboutId" />
						<div class="card-body">
							<div class="form-group">
								<label for="Title">Basligi Giriniz</label>
								<input type="text" class="form-control" asp-for="Title" id="Title">
							</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<label for="ImageUrl">Gorselin URL'ini Giriniz</label>
								<input type="text" class="form-control" asp-for="ImageUrl" id="ImageUrl">
							</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<label for="Description">Aciklamayi Giriniz</label>
								<textarea rows="5" class="form-control" asp-for="Description" itemid="Description"></textarea>
							</div>
						</div>
						<div class="card-action">
							<button class="btn btn-primary">Hakkimda yazisini guncelle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

